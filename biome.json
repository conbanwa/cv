{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["*.js", "*.ts", "*.jsx", "*.tsx"],
      "javascript": {
        "formatter": {
          "quoteStyle": "single",
          "semicolons": "asNeeded",
          "trailingCommas": "es5"
        }
      }
    },
    {
      "includes": ["*.css"],
      "css": {
        "formatter": {
          "quoteStyle": "single"
        }
      }
    }
  ]
}
